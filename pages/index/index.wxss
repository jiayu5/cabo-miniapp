/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: #f0f2f5;
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  padding: 60rpx 40rpx 40rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.header-title {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.title-main {
  font-size: 64rpx;
  font-weight: 900;
  color: #e94560;
  letter-spacing: 4rpx;
}

.title-sub {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.status-badge {
  background: rgba(233, 69, 96, 0.2);
  border: 1rpx solid #e94560;
  color: #e94560;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 40rpx;
}

/* 区块 */
.section {
  background: #ffffff;
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
}

.section-count {
  font-size: 24rpx;
  color: #aaaaaa;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  color: #bbbbbb;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-state text:last-child {
  font-size: 26rpx;
}

/* 玩家列表 */
.player-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.player-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  gap: 20rpx;
}

.player-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e94560, #c73652);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.player-avatar text {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.player-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.player-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.player-score {
  font-size: 24rpx;
  color: #e94560;
  font-weight: 500;
}

.player-score-idle {
  font-size: 24rpx;
  color: #bbbbbb;
}

.btn-delete {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #ffebee;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-delete text {
  font-size: 36rpx;
  color: #e94560;
  line-height: 1;
}

/* 添加玩家输入 */
.add-input-area {
  margin-top: 16rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.name-input {
  background: #ffffff;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333333;
  border: 2rpx solid #e0e0e0;
  margin-bottom: 16rpx;
}

.input-actions {
  display: flex;
  gap: 16rpx;
}

.btn-cancel {
  flex: 1;
  background: #f0f0f0;
  color: #666666;
  border-radius: 8rpx;
  border: none;
  font-size: 28rpx;
  padding: 16rpx;
}

.btn-cancel::after { border: none; }

.btn-confirm {
  flex: 1;
  background: #e94560;
  color: #ffffff;
  border-radius: 8rpx;
  border: none;
  font-size: 28rpx;
  padding: 16rpx;
}

.btn-confirm::after { border: none; }

/* 添加按钮 */
.add-player-btn {
  margin-top: 16rpx;
  padding: 24rpx;
  border: 2rpx dashed #e94560;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #e94560;
}

.add-icon {
  font-size: 40rpx;
  line-height: 1;
  font-weight: 300;
}

.add-player-btn text:last-child {
  font-size: 28rpx;
  font-weight: 500;
}

/* 操作按钮 */
.action-area {
  padding: 32rpx 24rpx 0;
}

.btn-start {
  width: 100%;
  background: linear-gradient(135deg, #e94560, #c73652);
  color: #ffffff;
  border-radius: 16rpx;
  border: none;
  font-size: 32rpx;
  font-weight: 700;
  padding: 28rpx;
  box-shadow: 0 6rpx 24rpx rgba(233, 69, 96, 0.4);
  letter-spacing: 4rpx;
}

.btn-start::after { border: none; }

.btn-start[disabled] {
  background: #cccccc;
  box-shadow: none;
  color: #ffffff;
}

.game-actions {
  display: flex;
  gap: 16rpx;
}

.btn-continue {
  flex: 2;
  background: linear-gradient(135deg, #e94560, #c73652);
  color: #ffffff;
  border-radius: 16rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 700;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(233, 69, 96, 0.4);
}

.btn-continue::after { border: none; }

.btn-reset {
  flex: 1;
  background: #f0f0f0;
  color: #666666;
  border-radius: 16rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 500;
  padding: 28rpx;
}

.btn-reset::after { border: none; }
