/* pages/game/game.wxss */
.container {
  min-height: 100vh;
  background: #f0f2f5;
  padding-bottom: 60rpx;
}

/* ====== 未开始状态 ====== */
.no-game {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 60rpx;
  gap: 20rpx;
}

.no-game-emoji {
  font-size: 100rpx;
}

.no-game-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
}

.no-game-sub {
  font-size: 26rpx;
  color: #999999;
  text-align: center;
}

.btn-go-setup {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #e94560, #c73652);
  color: #ffffff;
  border-radius: 16rpx;
  border: none;
  font-size: 28rpx;
  padding: 24rpx 60rpx;
}

.btn-go-setup::after { border: none; }

/* ====== 顶部信息栏 ====== */
.top-bar {
  background: linear-gradient(135deg, #1a1a2e, #16213e);
  padding: 40rpx 32rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.round-info {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  flex-shrink: 0;
}

.round-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.6);
}

.round-num {
  font-size: 64rpx;
  font-weight: 900;
  color: #e94560;
  line-height: 1;
}

/* 迷你总分榜 */
.score-board-mini {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.mini-score-item {
  background: rgba(255,255,255,0.1);
  border-radius: 8rpx;
  padding: 8rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 80rpx;
}

.mini-name {
  font-size: 20rpx;
  color: rgba(255,255,255,0.6);
  max-width: 80rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-score {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}

/* ====== 特殊事件提示 ====== */
.special-events {
  margin: 16rpx 24rpx 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.event-item {
  background: linear-gradient(135deg, #fff3e0, #fff8e1);
  border-left: 6rpx solid #ff9800;
  border-radius: 0 12rpx 12rpx 0;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #e65100;
  font-weight: 500;
}

/* ====== 记分表单 ====== */
.score-form {
  background: #ffffff;
  margin: 16rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
}

.form-title {
  font-size: 26rpx;
  color: #999999;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

/* 每行玩家分数 */
.score-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
  border-radius: 8rpx;
  transition: background 0.2s;
}

.score-row:last-child {
  border-bottom: none;
}

.row-cabo {
  background: rgba(233, 69, 96, 0.04);
  padding-left: 8rpx;
  padding-right: 8rpx;
}

.cabo-panel-name {
  color: #e94560;
  font-weight: 800;
}

/* Cabo标记按钮 */
.cabo-badge {
  width: 80rpx;
  height: 48rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 2rpx solid transparent;
}

.cabo-badge text {
  font-size: 18rpx;
  font-weight: 800;
  color: #999999;
  letter-spacing: 1rpx;
}

.cabo-active {
  background: rgba(233, 69, 96, 0.12);
  border-color: #e94560;
}

.cabo-active text {
  color: #e94560;
}

/* 玩家名称区域 */
.player-label {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.pl-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.pl-total {
  font-size: 22rpx;
  color: #999999;
}

/* 分数输入 */
.score-input-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.score-input {
  width: 100rpx;
  height: 64rpx;
  background: #f8f9fa;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #333333;
}

.input-win {
  background: rgba(76, 175, 80, 0.1);
  border-color: #4caf50;
  color: #4caf50;
}

.input-lose {
  background: rgba(233, 69, 96, 0.1);
  border-color: #e94560;
  color: #e94560;
}

.score-hint {
  font-size: 22rpx;
  font-weight: 700;
  color: #e94560;
  margin-left: 8rpx;
}

.score-win {
  color: #4caf50;
}

/* ====== Cabo结果面板 ====== */
.cabo-panel {
  background: #ffffff;
  margin: 16rpx 24rpx 0;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid rgba(233, 69, 96, 0.2);
}

.cabo-panel-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
  margin-bottom: 20rpx;
  text-align: center;
}

.cabo-panel-title text:first-child {
  color: #e94560;
  font-weight: 800;
}

.cabo-result-btns {
  display: flex;
  gap: 16rpx;
}

.cabo-result-btn {
  flex: 1;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  border: 2rpx solid transparent;
}

.result-emoji {
  font-size: 48rpx;
}

.result-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
}

.result-desc {
  font-size: 22rpx;
  color: #999999;
  text-align: center;
}

.result-selected-win {
  background: rgba(76, 175, 80, 0.1);
  border-color: #4caf50;
}

.result-selected-win .result-text {
  color: #4caf50;
}

.result-selected-lose {
  background: rgba(233, 69, 96, 0.1);
  border-color: #e94560;
}

.result-selected-lose .result-text {
  color: #e94560;
}

/* ====== 提交按钮 ====== */
.submit-area {
  padding: 24rpx;
}

.btn-submit {
  width: 100%;
  background: linear-gradient(135deg, #e94560, #c73652);
  color: #ffffff;
  border-radius: 16rpx;
  border: none;
  font-size: 32rpx;
  font-weight: 700;
  padding: 28rpx;
  box-shadow: 0 6rpx 24rpx rgba(233, 69, 96, 0.4);
  letter-spacing: 2rpx;
}

.btn-submit::after { border: none; }

/* ====== 游戏结束面板 ====== */
.game-over-panel {
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 40%, #0f3460 100%);
  display: flex;
  flex-direction: column;
  padding: 60rpx 32rpx 40rpx;
}

.game-over-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.game-over-title {
  font-size: 52rpx;
  font-weight: 900;
  color: #ffffff;
  display: block;
}

.game-over-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  margin-top: 8rpx;
  display: block;
}

.winner-area {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.winner-card {
  background: rgba(233, 69, 96, 0.15);
  border: 2rpx solid #e94560;
  border-radius: 24rpx;
  padding: 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.winner-crown {
  font-size: 64rpx;
}

.winner-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #ffffff;
}

.winner-score {
  font-size: 28rpx;
  color: #e94560;
  font-weight: 600;
}

.final-ranking {
  background: rgba(255,255,255,0.05);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.ranking-title {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  margin-bottom: 16rpx;
  display: block;
}

.ranking-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ranking-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: rgba(255,255,255,0.05);
}

.ranking-winner {
  background: rgba(233, 69, 96, 0.15);
}

.ranking-name {
  font-size: 28rpx;
  color: rgba(255,255,255,0.85);
}

.ranking-score {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
}

.game-over-actions {
  display: flex;
  gap: 16rpx;
}

.btn-history {
  flex: 1;
  background: rgba(255,255,255,0.1);
  color: rgba(255,255,255,0.8);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.2);
  font-size: 28rpx;
  padding: 24rpx;
}

.btn-history::after { border: none; }

.btn-new-game {
  flex: 2;
  background: linear-gradient(135deg, #e94560, #c73652);
  color: #ffffff;
  border-radius: 16rpx;
  border: none;
  font-size: 30rpx;
  font-weight: 700;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(233, 69, 96, 0.4);
}

.btn-new-game::after { border: none; }
